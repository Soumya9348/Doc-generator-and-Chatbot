WITH deduplicate_tariff AS (

  SELECT

    id,

    price_list,

    source,

    ingest_timestamp

  FROM `raw-emob-datahub`.ecomovement_api_tariffs

  QUALIFY ROW_NUMBER() OVER (PARTITION BY id ORDER BY ingest_timestamp DESC, source_file_ingest_timestamp DESC) = 1

),

raw_tariff AS (

  SELECT

    id,

    price,

    source,

    ingest_timestamp

  FROM deduplicate_tariff

  LATERAL VIEW EXPLODE(FROM_JSON(price_list, 'ARRAY<STRUCT<elements: ARRAY<STRUCT<price_excl_vat: STRING, type: STRING, vat: STRING>>, partner: STRING, product: STRUCT<currency: STRING, description: STRING, name: STRING, subscription_fee_excl_vat: STRING, subscription_type: STRING>>>')) AS price

),

distinct_raw_locations AS (

  SELECT *

  FROM (

    SELECT rcl.*,

      ROW_NUMBER() OVER (

        PARTITION BY rcl.id ORDER BY rcl.ingest_timestamp DESC

      ) AS row_num

    FROM `raw-emob-datahub`.ecomovement_api_locations rcl

  ) r

  WHERE r.row_num = 1

),

-- OPT: POSEXPLODE gives array index for free — removes one ROW_NUMBER window function
evse_explode AS (

  SELECT
    raw.id AS source_location_id,

    CONCAT(
      raw.id, '_',
      CAST(pos + 1 AS STRING)
    ) AS source_evse_id,

    e.*

  FROM distinct_raw_locations raw

  LATERAL VIEW POSEXPLODE(FROM_JSON(raw.evses,

    'ARRAY<STRUCT<uid: STRING, status: STRING, capabilities: ARRAY<STRING>, connectors: ARRAY<STRING>, last_updated: STRING, physical_reference: STRING, evse_id: STRING>>')) evse AS pos, e

),

-- OPT: TRANSFORM + FILTER + FLATTEN — parse & filter connectors INSIDE the array before exploding
-- This avoids the double LATERAL EXPLODE and eliminates rows with NULL pricing_id before they materialize
connector_explode AS (

  SELECT
    source_location_id,

    source_evse_id,

    '${source}' AS source,

    CONCAT(
      source_evse_id, '_',
      ROW_NUMBER() OVER(
        PARTITION BY source_evse_id ORDER BY v.id
      )
    ) AS source_connector_id,

    v.*

  FROM evse_explode e

  LATERAL VIEW EXPLODE(
    FILTER(
      FLATTEN(
        TRANSFORM(
          e.connectors,
          c -> FROM_JSON(c, 'ARRAY<STRUCT<id: STRING, standard: STRING, format: STRING, power_type: STRING, voltage: STRING, amperage: STRING, last_updated: STRING, pricing_id: STRING, max_power: STRING>>')
        )
      ),
      x -> x.pricing_id IS NOT NULL
    )
  ) tbl AS v

),

connector_remove_dups AS (

  SELECT *

  FROM (

    SELECT c.*,

      ROW_NUMBER() OVER(

        PARTITION BY c.source_connector_id,

          c.source_evse_id ORDER BY c.source_connector_id,

          c.source_evse_id

      ) AS row_num

    FROM connector_explode c

  ) r

  WHERE r.row_num = 1

),

-- OPT: BROADCAST hint — broadcasts smaller charger_connector table to all nodes, eliminates shuffle
-- OPT: SKEW hint — handles skewed source values to prevent executor hotspots
connector_tariff_id AS (

  SELECT /*+ BROADCAST(cc), SKEW('cc', 'source') */

    c.source,

    cc.connector_id,

    c.pricing_id AS source_tariff_id

  FROM connector_remove_dups c

  INNER JOIN `euh-emobility`.charger_connector cc

    ON c.source_connector_id = cc.source_connector_id AND cc.source = c.source

  -- OPT: pricing_id IS NOT NULL filter moved earlier into connector_explode via FILTER()

),

processed_tariff AS (

  SELECT

    id AS source_tariff_id,

    price.product.currency AS currency,

    price.product.description AS value_string,

    'All' AS payment_method,

    ARRAY("MONDAY", "TUESDAY", "WEDNESDAY", "THURSDAY", "FRIDAY", "SATURDAY", "SUNDAY") AS day,

    element.type AS type,

    CASE

      WHEN element.type = 'ENERGY' THEN 'kWh'

      WHEN element.type = 'TIME' THEN 'sec'

      WHEN element.type = 'FLAT' THEN price.product.currency

      ELSE NULL

    END AS unit,

    CASE

      WHEN element.type = 'ENERGY' THEN 1

      WHEN element.type = 'TIME' THEN 60

      ELSE NULL

    END AS value_numeric,

    CAST(element.price_excl_vat AS DECIMAL(5,2)) AS net_cost,

    CAST(element.vat AS DECIMAL(5,2)) AS vat,

    CAST(CAST(element.price_excl_vat AS DECIMAL(5,2)) * (1 + (CAST(element.vat AS DECIMAL(5,2)) / 100)) AS DECIMAL(5,2)) AS gross_cost,

    NULL AS start_time,
    NULL AS end_time,

    price.product.subscription_fee_excl_vat AS metric_string_1,

    NULL AS metric_string_2,

    CONCAT('{"subscription_fee_excl_vat":"', price.product.subscription_fee_excl_vat, '",',
      '"subscription_type":"', price.product.subscription_type, '",',
      '"partner":"', price.partner, '"}')
    AS metric_string_3,

    CURRENT_TIMESTAMP() AS created,

    CURRENT_TIMESTAMP() AS modified,

    ingest_timestamp AS processed,

    source

  FROM raw_tariff

  LATERAL VIEW EXPLODE(price.elements) AS element

),

-- OPT: SHUFFLE_HASH hint — forces hash join over sort-merge, skips expensive sort
result AS (

  SELECT /*+ SHUFFLE_HASH(c) */
    c.connector_id, pt.*

  FROM processed_tariff AS pt

  INNER JOIN connector_tariff_id AS c

    ON c.source_tariff_id = pt.source_tariff_id

)

SELECT *

FROM result

QUALIFY ROW_NUMBER() OVER (PARTITION BY connector_id, source_tariff_id, type, day, start_time, end_time, metric_string_3 ORDER BY processed DESC) = 1
